# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Supabase Configurations
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Connection string for SQLAlchemy (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-supabase-project-id.supabase.co:5432/postgres

# NVIDIA NIM API (Nemotron)
NEMOTRON_API_KEY=your_nvidia_nim_api_key_here

# Encryption Key (Fernet symmetric key - generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_fernet_encryption_key_here

# GitHub Personal Access Token (for workflow dispatch)
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repo_name

# Sentry (Optional)
SENTRY_DSN=
